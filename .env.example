# Local frontend proxy target (opsional saat jalankan tanpa Docker)
BACKEND_INTERNAL_URL=http://localhost:3001

# Biarkan kosong agar frontend pakai proxy internal /api/* (menghindari CORS browser)
PUBLIC_API_BASE_URL=

# Jika ingin direct browser -> API domain, isi URL API dan pastikan backend CORS benar:
# PUBLIC_API_BASE_URL=https://api-domain-anda.com
# CORS_ORIGIN=https://frontend-domain-anda.com
# CORS_CREDENTIALS=true
