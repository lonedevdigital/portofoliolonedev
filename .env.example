# Container internal ports (ubah dari Coolify env jika perlu)
BACKEND_PORT=3001
FRONTEND_PORT=4173

# URL internal backend untuk proxy server SvelteKit
BACKEND_INTERNAL_URL=http://backend:3001

# Opsional: set jika frontend perlu call API langsung dari browser
# PUBLIC_API_BASE_URL=https://api-domain-anda.com

# CORS backend (pakai * atau list origin dipisahkan koma)
CORS_ORIGIN=*
